{
  "name": "bemahub-open-enrollment-obs",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node server/server.js",
    "dev:vite": "vite",
    "build": "vite build",
    "start": "node server/server.js --production",
    "preview": "npm run build && npm run start",
    "review:capture": "node scripts/capture-review-package.mjs",
    "test:server": "node --test tests/controlStore.test.js",
    "test:scenes": "playwright test --grep-invert @visual",
    "test:visual": "playwright test --grep @visual",
    "test:visual:update": "playwright test --grep @visual --update-snapshots",
    "test": "playwright test"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@tailwindcss/vite": "^4.3.3",
    "@vitejs/plugin-react": "^6.0.3",
    "tailwindcss": "^4.3.3",
    "vite": "^8.1.1"
  },
  "dependencies": {
    "@fontsource-variable/inter": "^5.3.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  }
}
